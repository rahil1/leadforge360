{
  "name": "TeamMember",
  "type": "object",
  "properties": {
    "owner_email": {
      "type": "string",
      "description": "Email of the account owner"
    },
    "member_email": {
      "type": "string",
      "description": "Email of the invited team member"
    },
    "member_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "invited",
        "active",
        "removed"
      ],
      "default": "invited"
    },
    "role": {
      "type": "string",
      "default": "member"
    }
  },
  "required": [
    "owner_email",
    "member_email"
  ]
}
